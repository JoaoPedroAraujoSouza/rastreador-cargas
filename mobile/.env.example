# Copie este arquivo para .env e preencha os valores

# URL base da API backend (sem barra no final)
# Em desenvolvimento: IP local da sua máquina, ex: http://192.168.1.100:8080/api
# Em produção: URL do servidor, ex: https://api.seudominio.com
EXPO_PUBLIC_API_BASE_URL=http://SEU_IP_AQUI:8080/api

# Timeout das requisições em milissegundos
EXPO_PUBLIC_API_TIMEOUT=10000
