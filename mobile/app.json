{
  "expo": {
    "name": "Rastreador de Cargas",
    "slug": "rastreador-cargas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rastreadorcargas",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rastreadorcargas.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app uses your location to track cargo delivery in real time.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app uses your location in the background to continuously track cargo delivery."
      }
    },
    "android": {
      "package": "com.rastreadorcargas.app",
      "adaptiveIcon": {
        "backgroundColor": "#1e1e2d",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "This app uses your location to track cargo delivery in real time.",
          "locationWhenInUsePermission": "This app uses your location to track cargo delivery in real time."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1e1e2d",
          "dark": {
            "backgroundColor": "#1e1e2d"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
